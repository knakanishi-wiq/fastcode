# FastCode Environment Variables

# Model used by answer_generator.py (streaming/non-streaming generation).
# Must include vertex_ai/ prefix to route through VertexAI with ADC auth.
# NOTE: This var is independent of LITELLM_MODEL below — answer_generator.py reads MODEL first,
# then falls back to llm_client.DEFAULT_MODEL (LITELLM_MODEL). All other callers use LITELLM_MODEL only.
MODEL=vertex_ai/gemini-2.0-flash-001

# Default model for all LLM callers except answer_generator.py
# (query_processor, repo_selector, repo_overview, iterative_agent).
# llm_client.DEFAULT_MODEL reads this var; falls back to vertex_ai/gemini-2.0-flash-001 if unset.
# NOTE: This var is independent of MODEL above. Set both to the same value unless you intentionally
# want answer_generator to use a different model than query/retrieval callers.
LITELLM_MODEL=vertex_ai/gemini-2.0-flash-001

# ===== Nanobot Model (Agent Reasoning / Feishu Conversations) =====
NANOBOT_MODEL=minimax/minimax-m2.1

# ===== VertexAI / GCP Configuration =====
# Required for litellm vertex_ai/ calls via Application Default Credentials
# Auth: run `gcloud auth application-default login` before use
VERTEXAI_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=us-central1
# Model format: vertex_ai/<model-name> (always use vertex_ai/ prefix for ADC auth)
# Example: vertex_ai/gemini-3-flash-preview